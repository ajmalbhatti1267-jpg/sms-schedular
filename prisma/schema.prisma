// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  @@map("users")
}

model Contact {
  id          String   @id @default(cuid())
  name        String?
  phone       String
  email       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  messageLogs MessageLog[]

  @@map("contacts")
}

model ScheduledJob {
  id            String    @id @default(cuid())
  message       String
  scheduledAt   DateTime
  status        JobStatus @default(PENDING)
  totalContacts Int       @default(0)
  sentCount     Int       @default(0)
  failedCount   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  contactIds    String[]  // Store contact IDs as array
  messageLogs   MessageLog[]

  @@map("scheduled_jobs")
}

model MessageLog {
  id         String     @id @default(cuid())
  jobId      String
  contactId  String
  phone      String
  status     LogStatus  @default(PENDING)
  twilioSid  String?
  errorMsg   String?
  sentAt     DateTime?
  createdAt  DateTime   @default(now())

  job        ScheduledJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  contact    Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("message_logs")
}

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum LogStatus {
  PENDING
  SENT
  FAILED
  DELIVERED
}
